# =============================================================================
# WhatsApp Scam & Phishing Guardian Agent - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# WhatsApp API (Whapi.cloud)
# -----------------------------------------------------------------------------
# Your Whapi.cloud API token for WhatsApp connectivity.
# Get one at: https://whapi.cloud/
WHAPI_TOKEN=your_whapi_token_here

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------
# OpenAI API key for GPT-4o (primary LLM for message analysis).
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Groq API key (fallback LLM for speed/availability).
# Get one at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# -----------------------------------------------------------------------------
# Threat Intelligence APIs
# -----------------------------------------------------------------------------
# VirusTotal API key for URL reputation checking.
# Get one at: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# URLScan.io API key for phishing page detection.
# Get one at: https://urlscan.io/user/signup
URLSCAN_API_KEY=your_urlscan_api_key_here

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# SQLite database path for threat log storage.
# Default uses a local file; change for production deployments.
DATABASE_URL=sqlite:///data/threats.db

# -----------------------------------------------------------------------------
# WhatsApp Chat Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of WhatsApp chat IDs to monitor for threats.
# Example: 120363001234567890@g.us,120363009876543210@g.us
MONITORED_CHAT_IDS=

# Admin phone number for @mentions in DANGEROUS threat alerts.
# Use international format without '+' prefix (e.g., 1234567890).
ADMIN_PHONE_NUMBER=

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
